# ===================================
# IronCoach Environment Variables
# ===================================
# Copy this file to .env and fill in real values

# --- Database ---
DATABASE_URL="postgresql://ironcoach:ironcoach@localhost:5432/ironcoach?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# --- Auth (JWT) ---
# Generate with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-random-64-char-hex-string-minimum-32-characters"
JWT_REFRESH_SECRET="change-me-to-another-random-64-char-hex-string-min-32-chars"

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_PRICE_STARTER="price_starter_placeholder"
STRIPE_PRICE_GROWTH="price_growth_placeholder"
STRIPE_PRICE_PRO="price_pro_placeholder"
STRIPE_SUCCESS_URL="http://localhost:3000/billing/success"
STRIPE_CANCEL_URL="http://localhost:3000/billing/cancel"

# --- Cloudflare R2 (S3-compatible storage) ---
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY="your_r2_access_key"
R2_SECRET_KEY="your_r2_secret_key"
R2_BUCKET="ironcoach"
R2_PUBLIC_URL="https://your-bucket.r2.dev"
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"

# --- Resend (Email) ---
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="IronCoach <noreply@ironcoach.com>"

# --- Expo Push Notifications ---
EXPO_ACCESS_TOKEN="your_expo_access_token"
EAS_PROJECT_ID=""
EXPO_SLUG="ironcoach"

# --- Next.js ---
NEXTAUTH_SECRET="change-me-to-a-random-64-char-hex-string-minimum-32-characters"
NEXT_PUBLIC_API_URL="http://localhost:3001"

# --- URLs ---
APP_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# --- Monitoring ---
SENTRY_DSN=""

# --- BullMQ Dashboard ---
BULL_BOARD_USERNAME="admin"
BULL_BOARD_PASSWORD="admin"

# --- Server ---
PORT=3001
CORS_ORIGINS="http://localhost:3000"
NODE_ENV="development"
